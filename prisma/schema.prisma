// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")   // Pointe vers la version "Pooler"
  directUrl = env("DIRECT_URL")     // Pointe vers la version "Directe"
}

// Modèle pour capturer les emails sur ta Landing Page
model Subscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  role      String   @default("admin")
  createdAt DateTime @default(now())
}

model Post {
  id              String    @id @default(cuid())
  title           String
  slug            String    @unique
  content         String
  excerpt         String?
  metaDescription String?
  tag             String    @default("general")
  coverImage      String?
  published       Boolean   @default(false)
  publishedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([published, publishedAt])
  @@index([slug])
}

model Testimonial {
  id              String   @id @default(cuid())
  authorName      String
  authorRole      String
  location        String?
  quote           String
  metric          String?
  metricLabel     String?
  photoUrl        String?
  googleReviewUrl String?
  displayOrder    Int      @default(0)
  published       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([published, displayOrder])
}

// Jeton de connexion par lien email (usage unique, haché). Voir lib/auth-tokens.ts
model LoginToken {
  id        String    @id @default(cuid())
  email     String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([email])
}

model Project {
  id           String   @id @default(cuid())
  title        String
  tag          String                     // "SaaS & Automatisation", "Vitrine Premium"…
  description  String
  imageUrl     String?                    // null = carte "Projet confidentiel" (placeholder)
  url          String?                    // lien externe ; null = CTA "En discuter"
  ctaLabel     String?                    // override du libellé CTA (sinon auto selon url)
  accentColor  String   @default("gold")  // gold | blue | rose | emerald
  featured     Boolean  @default(false)   // true = grande carte pleine largeur en tête
  bullets      String[]                   // points "▸" listés dans la carte
  kpis         Json?                      // [{ value, label }] — affichés sur la carte featured
  displayOrder Int      @default(0)
  published    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([published, displayOrder])
}

model KapNumerikLead {
  id            String   @id @default(cuid())
  firstName     String
  email         String
  phone         String
  activityType  String
  consentRgpd   Boolean  @default(true)
  notifiedAt    DateTime?
  createdAt     DateTime @default(now())

  @@unique([email])
  @@index([createdAt])
}