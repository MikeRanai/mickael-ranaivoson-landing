// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")   // Pointe vers la version "Pooler"
  directUrl = env("DIRECT_URL")     // Pointe vers la version "Directe"
}

// Modèle pour capturer les emails sur ta Landing Page
model Subscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  role      String   @default("admin")
  createdAt DateTime @default(now())
}

model Post {
  id              String    @id @default(cuid())
  title           String
  slug            String    @unique
  content         String
  excerpt         String?
  metaDescription String?
  tag             String    @default("general")
  coverImage      String?
  published       Boolean   @default(false)
  publishedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([published, publishedAt])
  @@index([slug])
}

model Testimonial {
  id              String   @id @default(cuid())
  authorName      String
  authorRole      String
  location        String?
  quote           String
  metric          String?
  metricLabel     String?
  photoUrl        String?
  googleReviewUrl String?
  displayOrder    Int      @default(0)
  published       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([published, displayOrder])
}

model KapNumerikLead {
  id            String   @id @default(cuid())
  firstName     String
  email         String
  phone         String
  activityType  String
  consentRgpd   Boolean  @default(true)
  notifiedAt    DateTime?
  createdAt     DateTime @default(now())

  @@unique([email])
  @@index([createdAt])
}